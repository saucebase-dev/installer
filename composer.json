{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "saucebase/installer",
  "description": "The Saucebase application installer.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "composer-runtime-api": "^2.2",
    "guzzlehttp/guzzle": "^7.8",
    "illuminate/console": "^13.0",
    "illuminate/container": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/filesystem": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/support": "^13.0",
    "laravel/installer": "^5.14",
    "laravel/prompts": "^0.3",
    "symfony/process": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Saucebase\\Installer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Saucebase\\Installer\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/saucebase"
  ],
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
